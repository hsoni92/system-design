# ============================================================
# AWS (default credential chain: env vars or IAM role)
# Interview: Local = AWS_ACCESS_KEY_ID/SECRET, EC2/ECS/Lambda = IAM role
# ============================================================
AWS_REGION=us-east-1

# ============================================================
# RDS PostgreSQL (relational - connection from env)
# ============================================================
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=playground

# ============================================================
# DynamoDB (NoSQL - table name)
# ============================================================
DYNAMODB_TABLE=playground-items

# ============================================================
# SQS (messaging - queue URL)
# ============================================================
SQS_QUEUE_URL=

# ============================================================
# Secrets Manager (secret name - auth via default credential)
# ============================================================
SECRETS_MANAGER_SECRET_NAME=PLAYGROUND_SECRET

# ============================================================
# CloudWatch (optional - custom metrics namespace)
# ============================================================
CLOUDWATCH_NAMESPACE=AWSPlayground

# ============================================================
# Cognito (for JWT validation - optional; set to skip auth)
# ============================================================
COGNITO_ISSUER=          # e.g. https://cognito-idp.{region}.amazonaws.com/{userPoolId}
COGNITO_AUDIENCE=        # App client ID
COGNITO_JWKS_URI=        # https://cognito-idp.{region}.amazonaws.com/{userPoolId}/.well-known/jwks.json
SKIP_AUTH=false          # Set true to disable JWT validation (local dev only)
